<!-- /templates/cart.liquid -->
<!-- EDITORIAL CART V3 -->

<div class="ed-cart-container">
  <div class="ed-cart-header">
    <h1>Il Tuo Carrello</h1>
    <a href="/collections/all" class="ed-cart-continue">Continua gli acquisti</a>
  </div>

  {% if cart.item_count > 0 %}
    <form action="/cart" method="post" novalidate class="ed-cart-grid">
      <!-- Cart Items -->
      <div class="ed-cart-list">
        {% for item in cart.items %}
          <div class="ed-cart-item">
            <a href="{{ item.url }}">
              <img src="{{ item | img_url: 'medium' }}" alt="{{ item.title | escape }}" class="ed-cart-img">
            </a>
            
            <div class="ed-cart-details">
              <span class="ed-cart-brand">{{ item.vendor | default: "Xophia Exclusive" }}</span>
              <a href="{{ item.url }}" class="ed-cart-title">{{ item.product.title }}</a>
              
              {% unless item.variant.title contains 'Default' %}
                <div style="font-size: 13px; margin-bottom: 10px; color: #555;">{{ item.variant.title }}</div>
              {% endunless %}
              
              <div class="ed-cart-price">{{ item.price | money }}</div>
              
              <div class="ed-cart-actions">
                <div class="qty-selector" style="margin: 0; width: 120px; height: 40px;">
                  <button type="button" style="height: 40px; font-size: 16px;" onclick="var q = document.getElementById('updates_{{ item.key }}'); if(q.value>0) {q.value--; q.form.submit();} ">-</button>
                  <input type="number" name="updates[]" id="updates_{{ item.key }}" data-id="{{ item.key }}" value="{{ item.quantity }}" min="0" style="height: 40px; background: transparent;">
                  <button type="button" style="height: 40px; font-size: 16px;" onclick="var q = document.getElementById('updates_{{ item.key }}'); q.value++; q.form.submit();">+</button>
                </div>
                <a href="/cart/change?line={{ forloop.index }}&amp;quantity=0" class="ed-cart-remove">Rimuovi</a>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>

      <!-- Order Summary -->
      <div>
        <div class="ed-cart-summary">
          <h3 class="ed-summary-title">Riepilogo</h3>
          
          <div class="ed-summary-row">
            <span>Subtotale</span>
            <span>{{ cart.total_price | money }}</span>
          </div>
          
          {% if cart.total_discounts > 0 %}
            <div class="ed-summary-row" style="color: #d00;">
              <span>Sconti</span>
              <span>-{{ cart.total_discounts | money }}</span>
            </div>
          {% endif %}
          
          <div class="ed-summary-row" id="shipping-row">
            <span>Spedizione in Italia</span>
            <span style="font-weight: 600; color: #E64B77;">GRATIS</span>
          </div>

          <!-- Dynamic COD Fee Row (Hidden by default) -->
          <div class="ed-summary-row" id="cod-fee-row" style="display: none; color: #E64B77;">
            <span>Commissione Contrassegno</span>
            <span style="font-weight: 600;">2,00 €</span>
          </div>

          <div class="ed-summary-row ed-summary-total">
            <span id="total-text-label">Totale</span>
            <span id="cart-total-price" data-base-price="{{ cart.total_price }}">{{ cart.total_price | money }}</span>
          </div>

          <!-- ECOBIO STYLE INTERACTIVE PAYMENT SELECTOR -->
          <div class="ed-payment" style="margin-top: 30px;">
            <p style="font-size: 18px; font-weight: 500; margin-bottom: 5px;">Pagamento</p>
            <p style="font-size: 13px; color: #666; margin-bottom: 20px;">Tutte le transazioni sono sicure e crittografate.</p>

            <div class="ed-payment-selector">
              <!-- CARD ROW -->
              <label class="pm-row is-active" id="pm-row-card">
                <div class="pm-header">
                  <input type="radio" name="attributes[Payment_Method]" value="Carta di Credito" id="pay-card" checked>
                  <div class="pm-text">Carta di credito</div>
                  <div class="pm-icons">
                    <span class="pm-icon"><img src="https://cdn.shopify.com/s/assets/payment_icons/visa-319d545c6fd255c9aad5eeaad21fd6f7f7b4fdbdb1a35ce83b89cca12a187f00.svg" alt="Visa"></span>
                    <span class="pm-icon"><img src="https://cdn.shopify.com/s/assets/payment_icons/master-173035bc8124581983d4efa50cf8626e8553c2b311353fbf67485f9c1a2b88d1.svg" alt="Mastercard"></span>
                  </div>
                </div>
                <div class="pm-content">
                  <!-- No text needed for Card by default on EcoBio, but keeping standard Shopify safe. -->
                </div>
              </label>

              <!-- PAYPAL ROW -->
              <label class="pm-row" id="pm-row-paypal">
                <div class="pm-header">
                  <input type="radio" name="attributes[Payment_Method]" value="PayPal" id="pay-paypal">
                  <div class="pm-text">PayPal</div>
                  <div class="pm-icons">
                    <span class="pm-icon"><img src="https://cdn.shopify.com/s/assets/payment_icons/paypal-49e4c1e03244b6d2de0d270ca0d22dd15da6e92cc7266e93eb43762df5aa355d.svg" alt="PayPal"></span>
                  </div>
                </div>
              </label>

              <!-- COD ROW -->
              <label class="pm-row" id="pm-row-cod">
                <div class="pm-header">
                  <input type="radio" name="attributes[Payment_Method]" value="Cash on Delivery (COD)" id="pay-cod">
                  <div class="pm-text">Contrassegno (+2€)</div>
                  <div class="pm-icons">
                  </div>
                </div>
                <div class="pm-content">
                  <p style="margin: 0;">Paga comodamente i tuoi prodotti direttamente al corriere al momento della consegna. Per qualsiasi dubbio o informazione, il nostro servizio clienti è sempre a disposizione.</p>
                </div>
              </label>
            </div>
          </div>

          <p style="font-size: 12px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px;">Note dell'ordine (Opzionale):</p>
          <textarea name="note" style="width: 100%; border: 1px solid #ddd; padding: 15px; margin-bottom: 30px; min-height: 80px; font-family: 'Montserrat', sans-serif;">{{ cart.note }}</textarea>

          <button type="submit" name="update" style="display: none;">Update</button>
          <button type="submit" name="checkout" class="btn-editorial" style="width: 100%;">Procedi al Checkout</button>
        </div>
      </div>
    </form>
  {% else %}
    <div style="text-align: center; padding: 100px 0;">
      <h2 style="font-size: 32px; font-weight: 300; margin-bottom: 20px;">Il carrello è vuoto.</h2>
      <p style="color: #666; font-size: 16px; margin-bottom: 40px;">Non rinunciare all'eleganza, esplora le nostre collezioni.</p>
      <a href="/collections/all" class="btn-editorial" style="width: auto;">Inizia lo Shopping</a>
    </div>
  {% endif %}
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var codRadio = document.getElementById('pay-cod');
    var cardRadio = document.getElementById('pay-card');
    var paypalRadio = document.getElementById('pay-paypal');
    
    var rowCod = document.getElementById('pm-row-cod');
    var rowCard = document.getElementById('pm-row-card');
    var rowPaypal = document.getElementById('pm-row-paypal');

    var cartTotalEl = document.getElementById('cart-total-price');
    var totalTextLabel = document.getElementById('total-text-label');
    var codFeeRow = document.getElementById('cod-fee-row');
    
    // Shopify stores money in cents
    var basePriceCents = parseInt(cartTotalEl.getAttribute('data-base-price'));
    var moneyFormat = "{{ shop.money_format | default: '€{{amount_with_comma_separator}}' }}";

    // Basic money formatter if Shopify object isn't available
    function formatMoney(cents) {
      if (typeof Shopify !== 'undefined' && Shopify.formatMoney) {
        return Shopify.formatMoney(cents, moneyFormat);
      }
      return '€' + (cents / 100).toFixed(2).replace('.', ',');
    }

    function updatePaymentUI() {
      // Remove active class from all rows
      if(rowCod) rowCod.classList.remove('is-active');
      if(rowCard) rowCard.classList.remove('is-active');
      if(rowPaypal) rowPaypal.classList.remove('is-active');
      
      // Add active class dynamically
      if(codRadio && codRadio.checked) {
        if(rowCod) rowCod.classList.add('is-active');
        if(codFeeRow) codFeeRow.style.display = 'flex';
        if(totalTextLabel) totalTextLabel.innerHTML = 'Totale con Contrassegno<br><small style="font-size:11px; color:#999; text-transform:none; font-weight:normal;">(Inclusa commissione 2€)</small>';
        if(cartTotalEl) cartTotalEl.innerHTML = formatMoney(basePriceCents + 200); // Add 200 cents (2 Euros)
      } else {
        if (cardRadio && cardRadio.checked) {
          if(rowCard) rowCard.classList.add('is-active');
        } else if (paypalRadio && paypalRadio.checked) {
          if(rowPaypal) rowPaypal.classList.add('is-active');
        }
        if(codFeeRow) codFeeRow.style.display = 'none';
        if(totalTextLabel) totalTextLabel.innerHTML = 'Totale';
        if(cartTotalEl) cartTotalEl.innerHTML = formatMoney(basePriceCents);
      }
    }
    
    if(codRadio || cardRadio || paypalRadio) {
      if(codRadio) codRadio.addEventListener('change', updatePaymentUI);
      if(cardRadio) cardRadio.addEventListener('change', updatePaymentUI);
      if(paypalRadio) paypalRadio.addEventListener('change', updatePaymentUI);
      updatePaymentUI();
    }
  });
</script>