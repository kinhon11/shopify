<!-- /templates/cart.liquid -->
<!-- EDITORIAL CART V3 -->

<div class="ed-cart-container">
  <div class="ed-cart-header">
    <h1>Il Tuo Carrello</h1>
    <a href="/collections/all" class="ed-cart-continue">Continua gli acquisti</a>
  </div>

  {% if cart.item_count > 0 %}
    <form action="/cart" method="post" novalidate class="ed-cart-grid">
      <!-- Cart Items -->
      <div class="ed-cart-list">
        {% for item in cart.items %}
          <div class="ed-cart-item">
            <a href="{{ item.url }}">
              <img src="{{ item | img_url: 'medium' }}" alt="{{ item.title | escape }}" class="ed-cart-img">
            </a>
            
            <div class="ed-cart-details">
              <span class="ed-cart-brand">{{ item.vendor | default: "Xophia Exclusive" }}</span>
              <a href="{{ item.url }}" class="ed-cart-title">{{ item.product.title }}</a>
              
              {% unless item.variant.title contains 'Default' %}
                <div style="font-size: 13px; margin-bottom: 10px; color: #555;">{{ item.variant.title }}</div>
              {% endunless %}
              
              <div class="ed-cart-price">{{ item.price | money }}</div>
              
              <div class="ed-cart-actions">
                <div class="qty-selector" style="margin: 0; width: 120px; height: 40px;">
                  <button type="button" style="height: 40px; font-size: 16px;" onclick="var q = document.getElementById('updates_{{ item.key }}'); if(q.value>0) {q.value--; q.form.submit();} ">-</button>
                  <input type="number" name="updates[]" id="updates_{{ item.key }}" data-id="{{ item.key }}" value="{{ item.quantity }}" min="0" style="height: 40px; background: transparent;">
                  <button type="button" style="height: 40px; font-size: 16px;" onclick="var q = document.getElementById('updates_{{ item.key }}'); q.value++; q.form.submit();">+</button>
                </div>
                <a href="/cart/change?line={{ forloop.index }}&amp;quantity=0" class="ed-cart-remove">Rimuovi</a>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>

      <!-- Order Summary -->
      <div>
        <div class="ed-cart-summary">
          <h3 class="ed-summary-title">Riepilogo</h3>
          
          <div class="ed-summary-row">
            <span>Subtotale</span>
            <span>{{ cart.total_price | money }}</span>
          </div>
          
          {% if cart.total_discounts > 0 %}
            <div class="ed-summary-row" style="color: #d00;">
              <span>Sconti</span>
              <span>-{{ cart.total_discounts | money }}</span>
            </div>
          {% endif %}
          
          <div class="ed-summary-row">
            <span>Spedizione in Italia</span>
            <span style="font-weight: 600;">Gratuita (0€)</span>
          </div>

          <div class="ed-summary-row ed-summary-total">
            <span>Totale</span>
            <span>{{ cart.total_price | money }}</span>
          </div>

          <div class="ed-payment">
            <label>
              <input type="radio" name="attributes[Payment_Method]" value="Cash on Delivery (COD)" checked>
              Paga alla Consegna (COD)
            </label>
            <label>
              <input type="radio" name="attributes[Payment_Method]" value="PayPal / Credit Card">
              Carta di Credito / PayPal
            </label>
          </div>

          <p style="font-size: 12px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px;">Note dell'ordine (Opzionale):</p>
          <textarea name="note" style="width: 100%; border: 1px solid #ddd; padding: 15px; margin-bottom: 30px; min-height: 80px; font-family: 'Montserrat', sans-serif;">{{ cart.note }}</textarea>

          <button type="submit" name="update" style="display: none;">Update</button>
          <button type="submit" name="checkout" class="btn-editorial" style="width: 100%;">Procedi al Checkout</button>
        </div>
      </div>
    </form>
  {% else %}
    <div style="text-align: center; padding: 100px 0;">
      <h2 style="font-size: 32px; font-weight: 300; margin-bottom: 20px;">Il carrello è vuoto.</h2>
      <p style="color: #666; font-size: 16px; margin-bottom: 40px;">Non rinunciare all'eleganza, esplora le nostre collezioni.</p>
      <a href="/collections/all" class="btn-editorial" style="width: auto;">Inizia lo Shopping</a>
    </div>
  {% endif %}
</div>