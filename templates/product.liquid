<!-- /templates/product.liquid -->
<!-- EDITORIAL PRODUCT PAGE V3 -->
<div itemscope itemtype="http://schema.org/Product" class="ed-product-wrap">
  <meta itemprop="url" content="{{ shop.url }}{{ product.url }}">
  <meta itemprop="image" content="{{ product.featured_image.src | img_url: 'grande' }}">

  {% assign current_variant = product.selected_or_first_available_variant %}

  <!-- LEFT: Gallery Grid -->
  <div class="ed-gallery">
    {% assign featured_image = current_variant.featured_image | default: product.featured_image %}
    <img src="{{ featured_image | img_url: '1024x1024' }}" alt="{{ featured_image.alt | escape }}" id="ProductPhotoImg">
    {% if product.images.size > 1 %}
      {% for image in product.images offset: 1 %}
        <img src="{{ image.src | img_url: '1024x1024' }}" alt="{{ image.alt | escape }}">
      {% endfor %}
    {% else %}
      <!-- Placeholder if no other images -->
      <img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?auto=format&fit=crop&q=80&w=600" alt="Placeholder Moda">
    {% endif %}
  </div>

  <!-- RIGHT: Sticky Info -->
  <div class="ed-info">
    <span class="ed-brand-tag">{{ product.vendor | default: "Xophia Italia" }}</span>
    <h1 class="ed-title" itemprop="name">{{ product.title }}</h1>
    
    <div class="ed-price" itemprop="offers" itemscope itemtype="http://schema.org/Offer">
      <meta itemprop="priceCurrency" content="{{ shop.currency }}">
      <link itemprop="availability" href="http://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}">
      
      <span id="ProductPrice">{{ current_variant.price | money }}</span>
      {% if product.compare_at_price_max > product.price %}
        <s id="ComparePrice">{{ current_variant.compare_at_price | money }}</s>
      {% endif %}
    </div>

    <div class="ed-desc" itemprop="description">
      {{ product.description | default: "Dettagli esclusivi non ancora forniti. Questo prodotto rappresenta la massima espressione del design e dei materiali italiani. Progettato per resistere nel tempo, offre un'eleganza senza compromessi per il tuo armadio, corpo o casa." }}
    </div>

    <!-- Add to Cart Form -->
    <form action="/cart/add" method="post" enctype="multipart/form-data" id="AddToCartForm" class="ed-form">
      <!-- Variants hidden since we are forcing a minimal layout. Timber logic handles this drop-down by ID -->
      <select name="id" id="productSelect" style="display:none;">
        {% for variant in product.variants %}
          {% if variant.available %}
            <option {% if variant == product.selected_or_first_available_variant %} selected="selected" {% endif %} data-sku="{{ variant.sku }}" value="{{ variant.id }}">{{ variant.title }}</option>
          {% else %}
            <option disabled="disabled">{{ variant.title }} - Esaurito</option>
          {% endif %}
        {% endfor %}
      </select>

      <div class="qty-selector">
        <button type="button" onclick="var q = document.getElementById('Quantity'); if(q.value>1) q.value--;">-</button>
        <input type="number" id="Quantity" name="quantity" value="1" min="1">
        <button type="button" onclick="var q = document.getElementById('Quantity'); q.value++;">+</button>
      </div>

      <button type="submit" name="add" id="AddToCart" class="btn-editorial">
        <span id="AddToCartText">Aggiungi al Carrello</span>
      </button>
    </form>

    <div class="ed-trust">
      <div class="ed-trust-row">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
        <div class="ed-trust-info">
          <h5>Spedizione Priority Italia (0€)</h5>
          <p>La spedizione è sempre offerta da noi se il tuo carrello supera i 50 Euro.</p>
        </div>
      </div>
      <div class="ed-trust-row">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
        <div class="ed-trust-info">
          <h5>Acquisti Assicurati e Resi Facili</h5>
          <p>Acquista con sicurezza! Pagamenti crittografati e politica di reso a 30 giorni zero-stress.</p>
        </div>
      </div>
    </div>
  </div>
</div>

{{ 'option_selection.js' | shopify_asset_url | script_tag }}
<script>
  var selectCallback = function(variant, selector) {
    if (variant) {
      if (variant.available) {
        $('#AddToCart').removeClass('disabled').prop('disabled', false);
        $('#AddToCartText').text("Aggiungi al Carrello");
      } else {
        $('#AddToCart').addClass('disabled').prop('disabled', true);
        $('#AddToCartText').text("Esaurito");
      }
      if (variant.compare_at_price > variant.price) {
        $('#ComparePrice').html(Shopify.formatMoney(variant.compare_at_price, "{{ shop.money_format }}")).show();
      } else {
        $('#ComparePrice').hide();
      }
      $('#ProductPrice').html(Shopify.formatMoney(variant.price, "{{ shop.money_format }}"));
    }
  };

  jQuery(function($) {
    if($('#productSelect').length) {
      new Shopify.OptionSelectors('productSelect', {
        product: {{ product | json }},
        onVariantSelected: selectCallback,
        enableHistoryState: true
      });
      {% if product.variants.size == 1 and product.variants.first.title contains 'Default' %}
        $('.selector-wrapper').hide();
      {% endif %}
    }
  });
</script>
