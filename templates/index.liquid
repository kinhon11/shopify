<!-- /templates/index.liquid -->

<!-- Hero Section with Premium Video Background -->
<section class="hero-section video-hero">
  <!-- Looping Background Video -->
  <video autoplay muted loop playsinline class="hero-video-bg">
    <!-- Using a placeholder video link related to clean homes/kitchens for demo -->
    <source src="https://cdn.coverr.co/videos/coverr-pouring-coffee-into-a-glass-mug-5161/1080p.mp4" type="video/mp4">
  </video>
  <div class="hero-overlay"></div>

  <div class="hero-content glass-panel" style="background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);">
    <h1 class="hero-title" style="color: #fff; text-shadow: 0 4px 12px rgba(0,0,0,0.3);">Essenziali Intelligenti <br>per la Casa</h1>
    <p class="hero-subtitle" style="color: rgba(255,255,255,0.9); text-shadow: 0 2px 6px rgba(0,0,0,0.3);">Prodotti pratici pensati per semplificare la tua vita quotidiana</p>
    <a href="/collections/all" class="btn checkout-btn" style="display: inline-block; width: auto; padding: 16px 45px; border-radius: 40px; text-transform: uppercase; font-size: 15px; letter-spacing: 1.5px;">Scopri la Collezione</a>
  </div>
</section>

<!-- Trust Section -->
