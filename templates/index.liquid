<!-- Shop by Category -->
<section style="padding: 80px 0; background-color: #FAFAFA;">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Shop by Room</h2>
      <p style="color: var(--color-text-light);">Curated essentials for every space in your home.</p>
    </div>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px;">
      
      <a href="/collections/kitchen" style="position: relative; border-radius: 16px; overflow: hidden; display: block; aspect-ratio: 4/5; text-decoration: none; box-shadow: 0 10px 30px rgba(0,0,0,0.06); transition: transform 0.4s ease;">
        <img style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.8s ease;" src="https://images.unsplash.com/photo-1556911220-e15b29be8c8f?q=80&w=2670&auto=format&fit=crop" alt="Kitchen" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
        <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 30px 20px; background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);">
          <h3 style="color: #fff; margin: 0; font-size: 24px; text-shadow: 0 2px 4px rgba(0,0,0,0.3);">The Kitchen</h3>
          <span style="color: rgba(255,255,255,0.8); font-size: 14px;">Explore 120+ Products &rarr;</span>
        </div>
      </a>

      <a href="/collections/bathroom" style="position: relative; border-radius: 16px; overflow: hidden; display: block; aspect-ratio: 4/5; text-decoration: none; box-shadow: 0 10px 30px rgba(0,0,0,0.06); transition: transform 0.4s ease;">
        <img style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.8s ease;" src="https://images.unsplash.com/photo-1584622650111-993a426fbf0a?q=80&w=2670&auto=format&fit=crop" alt="Bathroom" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
        <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 30px 20px; background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);">
          <h3 style="color: #fff; margin: 0; font-size: 24px; text-shadow: 0 2px 4px rgba(0,0,0,0.3);">The Bathroom</h3>
          <span style="color: rgba(255,255,255,0.8); font-size: 14px;">Explore 85+ Products &rarr;</span>
        </div>
      </a>

      <a href="/collections/laundry" style="position: relative; border-radius: 16px; overflow: hidden; display: block; aspect-ratio: 4/5; text-decoration: none; box-shadow: 0 10px 30px rgba(0,0,0,0.06); transition: transform 0.4s ease;">
        <img style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.8s ease;" src="https://images.unsplash.com/photo-1545173168-9f1947eebb7f?q=80&w=2671&auto=format&fit=crop" alt="Laundry" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
        <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 30px 20px; background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);">
          <h3 style="color: #fff; margin: 0; font-size: 24px; text-shadow: 0 2px 4px rgba(0,0,0,0.3);">Laundry & Utility</h3>
          <span style="color: rgba(255,255,255,0.8); font-size: 14px;">Explore 40+ Products &rarr;</span>
        </div>
      </a>

    </div>
  </div>
</section>

<!-- Featured Products Section -->
<section class="featured-products">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Featured Essentials</h2>
      <p style="color: var(--color-text-light);">Our most loved household tools</p>
    </div>
    
    <div class="product-grid">
      {% for product in collections.frontpage.products limit:4 %}
        <div class="product-card">
          {% if product.compare_at_price > product.price %}
            <div class="discount-badge">Save {{ product.compare_at_price | minus: product.price | money_without_currency | times: 100 | divided_by: product.compare_at_price | round }}%</div>
          {% endif %}
          
          <a href="{{ product.url | within: collection }}" class="product-image-wrap">
            <img src="{{ product.featured_image.src | img_url: 'large' }}" alt="{{ product.featured_image.alt | escape }}">
          </a>
          
          <a href="{{ product.url | within: collection }}" class="product-title">{{ product.title }}</a>
          <div class="product-price">
            {% if product.compare_at_price > product.price %}
              <s style="color: var(--color-text-light); font-size: 14px; font-weight: 400; margin-right: 5px;">{{ product.compare_at_price | money }}</s>
            {% endif %}
            {{ product.price | money }}
          </div>
          
          <form method="post" action="/cart/add" class="add-to-cart-form">
            <input type="hidden" name="id" value="{{ product.variants.first.id }}" />
            <button type="submit" class="btn add-to-cart-btn">Add to Cart</button>
          </form>
        </div>
      {% else %}
        <!-- Demo Products Details -->
        <div class="product-card">
          <div class="discount-badge">New</div>
          <a href="#" class="product-image-wrap">
            <img src="https://via.placeholder.com/300x300/F4EFE6/7A8B6A?text=Product+1" alt="Smart Mop">
          </a>
          <a href="#" class="product-title">ErgoGrip Smart Mop</a>
          <div class="product-price">€29.99</div>
          <button class="btn add-to-cart-btn">Add to Cart</button>
        </div>

        <div class="product-card">
          <div class="discount-badge">-15%</div>
          <a href="#" class="product-image-wrap">
            <img src="https://via.placeholder.com/300x300/F4EFE6/7A8B6A?text=Product+2" alt="Kitchen Organizer">
          </a>
          <a href="#" class="product-title">Minimalist Spice Rack</a>
          <div class="product-price"><s style="color: var(--color-text-light); font-size: 14px; font-weight: 400; margin-right: 5px;">€35.00</s>€29.75</div>
          <button class="btn add-to-cart-btn">Add to Cart</button>
        </div>

        <div class="product-card">
          <a href="#" class="product-image-wrap">
            <img src="https://via.placeholder.com/300x300/F4EFE6/7A8B6A?text=Product+3" alt="Cleaning Set">
          </a>
          <a href="#" class="product-title">Eco-friendly Brush Set</a>
          <div class="product-price">€18.50</div>
          <button class="btn add-to-cart-btn">Add to Cart</button>
        </div>

        <div class="product-card">
          <div class="discount-badge">-10%</div>
          <a href="#" class="product-image-wrap">
            <img src="https://via.placeholder.com/300x300/F4EFE6/7A8B6A?text=Product+4" alt="Vacuum">
          </a>
          <a href="#" class="product-title">Compact Cordless Vacuum</a>
          <div class="product-price"><s style="color: var(--color-text-light); font-size: 14px; font-weight: 400; margin-right: 5px;">€110.00</s>€99.00</div>
          <button class="btn add-to-cart-btn">Add to Cart</button>
        </div>
      {% endfor %}
    </div>
    
    <div style="text-align: center; margin-top: 40px;">
      <a href="/collections/all" class="btn btn--outline">View All Products</a>
    </div>
  </div>
</section>

