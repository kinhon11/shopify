<!-- /templates/index.liquid -->
<!-- HIGH-END EDITORIAL ITALIAN MARKETPLACE -->

<div class="editorial-hero">
  <!-- Soft muted moving video or image background -->
  <video class="hero-video" src="https://cdn.shopify.com/s/files/1/0879/2925/8287/files/luxury-video.mp4?v=17387201" autoplay loop muted playsinline poster="//cdn.shopify.com/s/files/1/0533/2089/files/placeholder-hero.jpg"></video>
  <div class="overlay" style="position: absolute; top:0; left:0; right:0; bottom:0; background: rgba(0,0,0,0.5); z-index:1;"></div>
  
  <div class="hero-content">
    <span class="hero-tag">Il Nuovo Arrivo</span>
    <h1>L'Arte di Vivere</h1>
    <p>La collezione curata dai migliori designer italiani per la tua casa, armadio e vita.</p>
    <a href="/collections/all" class="btn-editorial btn-hero">Esplora la Collezione</a>
  </div>
</div>

<div class="category-showcase">
  <!-- Cat 1: Home -->
  <a href="/collections/la-casa" class="cat-box">
    <img src="https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?auto=format&fit=crop&q=80&w=800" alt="La Casa">
    <div class="overlay"></div>
    <div class="cat-title-wrap">
      <h3>La Casa</h3>
      <span>Acquista ora</span>
    </div>
  </a>

  <!-- Cat 2: Fashion -->
  <a href="/collections/la-moda" class="cat-box">
    <img src="https://images.unsplash.com/photo-1490481651871-ab68de25d43d?auto=format&fit=crop&q=80&w=800" alt="La Moda">
    <div class="overlay"></div>
    <div class="cat-title-wrap">
      <h3>La Moda</h3>
      <span>Acquista ora</span>
    </div>
  </a>

  <!-- Cat 3: Beauty -->
  <a href="/collections/la-bellezza" class="cat-box">
    <img src="https://images.unsplash.com/photo-1596462502278-27bfdc403348?auto=format&fit=crop&q=80&w=800" alt="La Bellezza">
    <div class="overlay"></div>
    <div class="cat-title-wrap">
      <h3>La Bellezza</h3>
      <span>Acquista ora</span>
    </div>
  </a>

  <!-- Cat 4: Electronics / Gifts -->
  <a href="/collections/regali" class="cat-box">
    <img src="https://images.unsplash.com/photo-1505740420928-5e560c06d30e?auto=format&fit=crop&q=80&w=800" alt="Regali Esclusivi">
    <div class="overlay"></div>
    <div class="cat-title-wrap">
      <h3>I Regali</h3>
      <span>Acquista ora</span>
    </div>
  </a>
</div>

<div class="editorial-products">
  <div class="section-title-wrap">
    <h2>La Selezione</h2>
    <a href="/collections/all">Vedi Tutti i Prodotti &rarr;</a>
  </div>

  <div class="prod-grid">
    {% assign collection = collections['all'] %}
    {% for product in collection.products limit: 8 %}
      <div class="prod-card">
        <div class="prod-img">
          <a href="{{ product.url | within: collection }}" style="display:block; height:100%;">
            <img src="{{ product.featured_image.src | img_url: 'large' }}" alt="{{ product.featured_image.alt | escape }}">
          </a>
          <form action="/cart/add" method="post" class="prod-quick-add-form">
            <input type="hidden" name="id" value="{{ product.variants.first.id }}">
            <button type="submit" class="prod-quick-add">Aggiungi Rapido</button>
          </form>
        </div>
        <span class="prod-brand">{{ product.vendor | default: "Xophia Exclusive" }}</span>
        <a href="{{ product.url | within: collection }}" class="prod-title">{{ product.title }}</a>
        <div class="prod-price">{{ product.price | money }}</div>
      </div>
    {% else %}
      {% for i in (1..4) %}
        <div class="prod-card">
          <div class="prod-img">
            <img src="https://images.unsplash.com/photo-1581093458791-9f3c3900df4b?auto=format&fit=crop&q=80&w=600" alt="Placeholder">
            <button class="prod-quick-add">Aggiungi Rapido</button>
          </div>
          <span class="prod-brand">Made in Italy</span>
          <a href="#" class="prod-title">Prodotto Esempio {{ i }}</a>
          <div class="prod-price">90,00 Euro</div>
        </div>
      {% endfor %}
    {% endfor %}
  </div>
</div>
