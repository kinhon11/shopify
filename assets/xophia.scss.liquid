/* Xophia Custom Styles */


  $color-primary-bg: #FDFBF7; /* Warm beige / soft cream */
  $color-accent: #7A8B6A; /* Olive green */
  $color-accent-hover: #637254;
  $color-text-main: #2C2C2C; /* Dark grey for elegant text */
  $color-text-light: #666666;
  $color-white: #FFFFFF;
  $color-border: #E8E8E8;
  
  $font-family-main: 'Inter', 'Helvetica Neue', Arial, sans-serif;
  $font-family-heading: 'Outfit', 'Helvetica Neue', Arial, sans-serif;
  
  $radius-sm: 8px;
  $radius-md: 16px;
  $radius-lg: 24px;
  
  $shadow-soft: 0 10px 30px rgba(0,0,0,0.05);
  $shadow-hover: 0 15px 40px rgba(0,0,0,0.08);
  
  $transition-smooth: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);


body {
  font-family: $font-family-main;
  color: $color-text-main;
  background-color: $color-primary-bg;
  line-height: 1.6;
}

h1, h2, h3, h4, h5, h6 {
  font-family: $font-family-heading;
  font-weight: 500;
  color: $color-text-main;
  letter-spacing: -0.02em;
}

/* Base utilities */
.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 20px;
}

.text-center { text-align: center; }

.btn {
  display: inline-block;
  padding: 14px 28px;
  background-color: $color-accent;
  color: $color-white;
  border-radius: $radius-lg;
  font-weight: 500;
  transition: $transition-smooth;
  border: none;
  cursor: pointer;
  text-decoration: none;
  font-family: $font-family-main;
}
.btn:hover {
  background-color: $color-accent-hover;
  transform: translateY(-2px);
  box-shadow: $shadow-soft;
  color: $color-white;
}
.btn--outline {
  background-color: transparent;
  border: 1px solid $color-accent;
  color: $color-accent;
}
.btn--outline:hover {
  background-color: $color-accent;
  color: $color-white;
}

/* Header */
.xophia-header {
  position: sticky;
  top: 0;
  z-index: 1000;
  background-color: rgba(253, 251, 247, 0.9);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid $color-border;
  padding: 15px 0;
  transition: $transition-smooth;
}
.xophia-header-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.header-logo a {
  font-family: $font-family-heading;
  font-size: 28px;
  font-weight: 600;
  color: $color-text-main;
  text-decoration: none;
  letter-spacing: -0.03em;
}
.header-nav {
  display: none;
}
@media (min-width: 768px) {
  .header-nav {
    display: flex;
    gap: 30px;
  }
}
.header-nav a {
  color: $color-text-main;
  text-decoration: none;
  font-size: 15px;
  font-weight: 500;
  transition: color 0.2s;
}
.header-nav a:hover {
  color: $color-accent;
}
.header-icons {
  display: flex;
  gap: 20px;
  align-items: center;
}
.header-icons a {
  color: $color-text-main;
  cursor: pointer;
  display: flex;
  position: relative;
  text-decoration: none;
}
.header-icons svg {
  width: 22px;
  height: 22px;
}
.cart-count {
  position: absolute;
  top: -8px;
  right: -8px;
  background: $color-accent;
  color: $color-white;
  font-size: 11px;
  width: 18px;
  height: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-weight: 600;
}

/* Hero Section */
.hero-section {
  padding: 120px 20px;
  background-color: #F4EFE6;
  background-image: url('https://images.unsplash.com/photo-1584622201383-7c2a715f5fc9?q=80&w=2670&auto=format&fit=crop');
  background-size: cover;
  background-position: center;
  border-radius: $radius-lg;
  margin: 30px 20px;
  text-align: center;
  position: relative;
  overflow: hidden;
  box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
}
.hero-section::before {
  content: "";
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.4) 100%);
  z-index: 1;
}
.hero-content {
  max-width: 650px;
  margin: 0 auto;
  position: relative;
  z-index: 2;
  padding: 50px 40px;
  border-radius: $radius-lg;
}
.hero-title {
  font-size: 56px;
  line-height: 1.1;
  margin-bottom: 20px;
  color: #fff;
  text-shadow: 0 4px 15px rgba(0,0,0,0.1);
}
@media (max-width: 767px) {
  .hero-title {
    font-size: 38px;
  }
}
.hero-subtitle {
  font-size: 20px;
  color: rgba(255,255,255,0.95);
  margin-bottom: 35px;
  font-weight: 400;
  text-shadow: 0 2px 8px rgba(0,0,0,0.2);
}


/* Trust Section */
.trust-section {
  padding: 40px 0;
  background-color: $color-white;
  border-top: 1px solid $color-border;
  border-bottom: 1px solid $color-border;
}
.trust-grid {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 20px;
}
.trust-item {
  display: flex;
  align-items: center;
  gap: 12px;
  flex: 1;
  min-width: 200px;
  cursor: pointer;
}
.trust-item:hover .trust-icon {
  background: $color-accent;
  color: $color-white;
  transform: rotate(5deg) scale(1.1);
}
.trust-item:hover .trust-text {
  color: $color-accent;
}
.trust-icon {
  width: 40px;
  height: 40px;
  background: $color-primary-bg;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: $color-accent;
  transition: $transition-smooth;
}
.trust-text {
  font-weight: 500;
  font-size: 14px;
  transition: $transition-smooth;
}

/* Featured Products */
.featured-products {
  padding: 80px 0;
}
.section-header {
  text-align: center;
  margin-bottom: 50px;
}
.section-title {
  font-size: 32px;
  margin-bottom: 10px;
}
.product-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 30px;
}
.product-card {
  background: $color-white;
  border-radius: $radius-md;
  padding: 15px;
  transition: $transition-smooth;
  box-shadow: 0 4px 6px rgba(0,0,0,0.02);
  text-align: center;
  position: relative;
}
.product-card:hover {
  transform: translateY(-5px);
  box-shadow: $shadow-hover;
}
.product-image-wrap {
  position: relative;
  padding-bottom: 100%;
  border-radius: $radius-sm;
  background: #f9f9f9;
  overflow: hidden;
  margin-bottom: 15px;
  display: block;
}
.product-image-wrap img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: contain;
  transition: transform 0.5s cubic-bezier(0.25, 0.8, 0.25, 1);
}
.product-card:hover .product-image-wrap img {
  transform: scale(1.08);
}
.discount-badge {
  position: absolute;
  top: 10px;
  left: 10px;
  background: #E07A5F; /* Terracotta */
  color: white;
  padding: 4px 10px;
  font-size: 12px;
  font-weight: 600;
  border-radius: 20px;
  z-index: 2;
}
.product-title {
  font-size: 16px;
  font-weight: 500;
  margin-bottom: 10px;
  color: $color-text-main;
  text-decoration: none;
  display: block;
}
.product-price {
  font-weight: 600;
  color: $color-accent;
  margin-bottom: 15px;
}
.add-to-cart-btn {
  width: 100%;
  padding: 10px;
  font-size: 14px;
}

/* Benefits Section */
.benefits-section {
  padding: 80px 0;
  background-color: $color-white;
}
.benefits-wrapper {
  display: flex;
  align-items: center;
  gap: 50px;
  flex-wrap: wrap;
}
.benefits-content {
  flex: 1;
  min-width: 300px;
}
.benefits-list {
  list-style: none;
  padding: 0;
  margin-top: 30px;
}
.benefits-list li {
  display: flex;
  align-items: flex-start;
  gap: 15px;
  margin-bottom: 25px;
}
.benefit-icon {
  background: rgba(122, 139, 106, 0.1);
  color: $color-accent;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.benefit-icon svg { width: 24px; height: 24px; }
.benefit-text h4 { margin: 0 0 5px 0; font-size: 18px; }
.benefit-text p { margin: 0; color: $color-text-light; font-size: 14px; }
.benefits-image {
  flex: 1;
  min-width: 300px;
  border-radius: $radius-lg;
  overflow: hidden;
}
.benefits-image img {
  width: 100%;
  height: auto;
  display: block;
}

/* Reviews Section */
.reviews-section {
  padding: 80px 0;
}
.reviews-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 30px;
}
.review-card {
  background: $color-white;
  padding: 30px;
  border-radius: $radius-md;
  box-shadow: $shadow-soft;
  transition: transform 0.4s ease, box-shadow 0.4s ease;
  border: 1px solid transparent;
}
.review-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 20px 40px rgba(0,0,0,0.08);
  border-color: rgba(122, 139, 106, 0.2);
}
.stars {
  color: #F4C150;
  margin-bottom: 15px;
}
.review-text {
  font-style: italic;
  margin-bottom: 20px;
  color: $color-text-main;
  font-size: 15px;
}
.reviewer-name {
  font-weight: 600;
  font-size: 14px;
}

/* Footer */
.xophia-footer {
  background-color: $color-white;
  padding: 60px 0 30px;
  border-top: 1px solid $color-border;
}
.footer-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 40px;
  margin-bottom: 40px;
}
.footer-col h4 {
  font-size: 16px;
  margin-bottom: 20px;
  font-weight: 600;
}
.footer-col ul {
  list-style: none;
  padding: 0;
  margin: 0;
}
.footer-col ul li {
  margin-bottom: 10px;
}
.footer-col ul li a {
  color: $color-text-light;
  text-decoration: none;
  transition: color 0.2s;
  font-size: 14px;
}
.footer-col ul li a:hover {
  color: $color-accent;
}
.social-icons {
  display: flex;
  gap: 15px;
  margin-top: 15px;
}
.social-icons a {
  color: $color-text-main;
  background: $color-primary-bg;
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: $transition-smooth;
}
.social-icons a:hover {
  background: $color-accent;
  color: $color-white;
}
.footer-bottom {
  text-align: center;
  padding-top: 30px;
  border-top: 1px solid $color-border;
  color: $color-text-light;
  font-size: 13px;
}

/* --- NEW PREMIUM UPGRADES --- */

/* Animations */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes shine {
  0% { background-position: -200% center; }
  100% { background-position: 200% center; }
}
@keyframes float {
  0% { transform: translateY(0px); }
  50% { transform: translateY(-8px); }
  100% { transform: translateY(0px); }
}

body {
  animation: fadeInUp 0.8s ease-out forwards;
}

/* Glassmorphism elements */
.glass-panel {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.07);
}

/* Enhanced Logo */
.header-logo a.xophia-text-logo {
  font-family: $font-family-heading;
  font-size: 32px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 2px;
  background: linear-gradient(120deg, $color-text-main 20%, $color-accent 50%, $color-text-main 80%);
  background-size: 200% auto;
  color: #000;
  background-clip: text;
  text-fill-color: transparent;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  animation: shine 4s linear infinite;
  display: inline-flex;
  align-items: center;
  gap: 8px;
}
.header-logo a.xophia-text-logo svg {
  width: 28px;
  height: 28px;
  color: $color-accent;
  animation: float 3s ease-in-out infinite;
}

/* Payment Selector UI */
.payment-selector {
  margin: 30px 0;
  text-align: left;
  background: #fff;
  padding: 20px;
  border-radius: $radius-md;
  box-shadow: $shadow-soft;
}
.payment-selector h4 {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 15px;
  color: $color-text-main;
}
.payment-options {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.payment-options input[type="radio"] {
  display: none;
}
.payment-option-label {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px;
  border: 2px solid $color-border;
  border-radius: $radius-sm;
  cursor: pointer;
  transition: $transition-smooth;
}
.payment-option-label:hover {
  border-color: rgba(122, 139, 106, 0.4);
  background: rgba(122, 139, 106, 0.02);
}
.payment-options input[type="radio"]:checked + .payment-option-label {
  border-color: $color-accent;
  background: rgba(122, 139, 106, 0.05);
  box-shadow: 0 4px 15px rgba(122, 139, 106, 0.1);
}
.po-left {
  display: flex;
  align-items: center;
  gap: 15px;
}
.po-radio-circle {
  width: 20px;
  height: 20px;
  border: 2px solid $color-border;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: $transition-smooth;
}
.po-radio-circle::after {
  content: '';
  width: 10px;
  height: 10px;
  background: $color-accent;
  border-radius: 50%;
  transform: scale(0);
  transition: $transition-smooth;
}
.payment-options input[type="radio"]:checked + .payment-option-label .po-radio-circle {
  border-color: $color-accent;
}
.payment-options input[type="radio"]:checked + .payment-option-label .po-radio-circle::after {
  transform: scale(1);
}
.po-text {
  font-size: 15px;
  font-weight: 600;
  color: $color-text-main;
}
.po-desc {
  font-size: 13px;
  color: $color-text-light;
  margin-top: 2px;
}

/* Make checkout button pop */
.checkout-btn {
  width: 100%;
  font-size: 18px;
  padding: 16px;
  background: linear-gradient(135deg, $color-accent 0%, #57654a 100%);
  border-radius: $radius-md;
  box-shadow: 0 10px 20px rgba(122, 139, 106, 0.25);
  margin-top: 15px;
  font-weight: 600;
  letter-spacing: 0.5px;
}
.checkout-btn:hover {
  transform: translateY(-3px);
  box-shadow: 0 15px 30px rgba(122, 139, 106, 0.35);
}

/* Fancy Product Cards Glassmorphism */
.product-card {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255,255,255,0.5);
}


// Additional Premium Styles

.product-card .add-to-cart-form {
  position: absolute;
  bottom: -60px;
  left: 0;
  width: 100%;
  padding: 0 15px 15px;
  opacity: 0;
  transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
  z-index: 10;
}
.product-card:hover .add-to-cart-form {
  bottom: 0px;
  opacity: 1;
}

/* Marquee / Announcement Bar */
.xophia-announcement-bar {
  background: #111;
  color: #fff;
  padding: 8px 0;
  overflow: hidden;
  white-space: nowrap;
  font-size: 13px;
  letter-spacing: 2px;
  font-weight: 600;
  text-transform: uppercase;
  border-bottom: 1px solid rgba(255,255,255,0.1);
  position: relative;
  z-index: 1001;
}
.marquee-content {
  display: inline-block;
  animation: marquee 25s linear infinite;
  padding-left: 100%;
}
.marquee-content span {
  display: inline-block;
}
.marquee-content .dot {
  color: -accent;
  margin: 0 25px;
}
@keyframes marquee {
  0% { transform: translateX(0); }
  100% { transform: translateX(-100%); }
}

/* Video Hero Styles */
.video-hero {
  position: relative;
  overflow: hidden;
  padding: 180px 20px;
  background-image: none !important;
  border-radius: 0;
  margin: 0;
}
.hero-video-bg {
  position: absolute;
  top: 50%;
  left: 50%;
  min-width: 100%;
  min-height: 100%;
  width: auto;
  height: auto;
  z-index: 0;
  transform: translateX(-50%) translateY(-50%);
  object-fit: cover;
}
.hero-overlay {
  position: absolute;
  top: 0; right: 0; bottom: 0; left: 0;
  background: linear-gradient(135deg, rgba(30,30,30,0.6) 0%, rgba(122,139,106,0.5) 100%);
  z-index: 1;
}
.video-hero .glass-panel {
  box-shadow: 0 25px 50px rgba(0,0,0,0.3) !important;
  border-radius: 30px !important;
  padding: 60px 40px;
}

/* =========================================================================
   EXTREME MAKEOVER - PREMIUM PRODUCT PAGE
========================================================================= */
.xophia-product-page {
  max-width: 1400px;
  margin: 40px auto;
  padding: 0 40px;
}
.product-premium-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: start;
}
@media (max-width: 900px) {
  .product-premium-grid {
    grid-template-columns: 1fr;
    gap: 40px;
  }
}
.product-gallery-main img {
  width: 100%;
  border-radius: 20px;
  box-shadow: 0 20px 40px rgba(0,0,0,0.08);
  object-fit: cover;
  transition: transform 0.4s ease;
}
.product-thumbnails {
  display: flex;
  gap: 15px;
  margin-top: 20px;
  overflow-x: auto;
  padding-bottom: 10px;
}
.product-thumb img {
  width: 80px;
  height: 80px;
  border-radius: 12px;
  object-fit: cover;
  border: 2px solid transparent;
  cursor: pointer;
  transition: border-color 0.3s ease;
}
.product-thumb:hover img {
  border-color: \-accent;
}

.product-details-sticky {
  position: sticky;
  top: 120px;
}
.product-title-large {
  font-family: \-family-heading;
  font-size: 44px;
  font-weight: 800;
  line-height: 1.1;
  margin-bottom: 15px;
  color: \-text-main;
}
.product-reviews-badge {
  color: #F4C150;
  font-size: 16px;
  margin-bottom: 25px;
}
.review-count {
  color: \-text-light;
  font-size: 14px;
  margin-left: 8px;
}
.product-price-large {
  display: flex;
  align-items: center;
  gap: 15px;
  margin-bottom: 30px;
}
.current-price {
  font-size: 32px;
  font-weight: 700;
  color: \-accent;
}
.old-price {
  font-size: 20px;
  color: \-text-light;
}
.sale-badge {
  background: #E07A5F;
  color: #fff;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: bold;
  text-transform: uppercase;
}
.product-description-short {
  font-size: 16px;
  line-height: 1.8;
  color: \-text-light;
  margin-bottom: 40px;
}
.premium-add-form {
  background: #fff;
  padding: 30px;
  border-radius: 20px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.04);
  border: 1px solid \-border;
  margin-bottom: 30px;
}
.action-row {
  display: flex;
  gap: 20px;
  align-items: center;
}
.qty-wrapper {
  display: flex;
  align-items: center;
  border: 1px solid \-border;
  border-radius: 12px;
  overflow: hidden;
  height: 54px;
}
.qty-btn {
  background: #f9f9f9;
  border: none;
  width: 40px;
  font-size: 20px;
  cursor: pointer;
  transition: background 0.2s;
  height: 100%;
}
.qty-btn:hover {
  background: #eee;
}
.qty-input {
  width: 50px;
  border: none;
  text-align: center;
  font-weight: bold;
  font-size: 16px;
  height: 100%;
  -moz-appearance: textfield;
}
.qty-input::-webkit-outer-spin-button, .qty-input::-webkit-inner-spin-button {
  -webkit-appearance: none;
  margin: 0;
}
.add-to-cart-premium {
  flex: 1;
  height: 54px;
  margin: 0;
}

.product-trust-box {
  background: rgba(122, 139, 106, 0.05);
  border-radius: 16px;
  padding: 25px;
}
.trust-row {
  display: flex;
  align-items: center;
  gap: 15px;
  margin-bottom: 15px;
  font-size: 15px;
  color: \-text-main;
}
.trust-row:last-child {
  margin-bottom: 0;
}
.trust-row svg {
  width: 24px;
  height: 24px;
  color: \-accent;
}

/* =========================================================================
   EXTREME MAKEOVER - PREMIUM CART PAGE
========================================================================= */
.premium-cart-page {
  padding: 60px 40px;
  max-width: 1400px;
  margin: 0 auto;
}
.cart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40px;
  border-bottom: 2px solid \-border;
  padding-bottom: 20px;
}
.cart-title {
  font-size: 36px;
  font-weight: 800;
  margin: 0;
}
.continue-shopping {
  color: \-text-light;
  font-weight: 500;
  text-decoration: underline;
  font-size: 16px;
}
.cart-layout-grid {
  display: grid;
  grid-template-columns: 2fr 1.2fr;
  gap: 60px;
}
@media (max-width: 900px) {
  .cart-layout-grid {
    grid-template-columns: 1fr;
    gap: 40px;
  }
}
.cart-item-premium {
  display: flex;
  align-items: center;
  gap: 25px;
  margin-bottom: 25px;
  border: 1px solid \-border;
  transition: transform 0.3s ease;
}
.cart-item-premium:hover {
  transform: translateY(-5px);
  border-color: rgba(122, 139, 106, 0.3);
}
.ci-image img {
  width: 140px;
  border-radius: 12px;
  box-shadow: 0 5px 15px rgba(0,0,0,0.05);
}
.ci-details {
  flex: 1;
}
.ci-title {
  font-size: 20px;
  font-weight: 600;
  color: \-text-main;
  display: block;
  margin-bottom: 5px;
}
.ci-variant {
  font-size: 14px;
  color: \-text-light;
  margin-bottom: 15px;
}
.ci-price {
  font-weight: 700;
  font-size: 18px;
  margin-bottom: 20px;
  color: \-accent;
}
.ci-actions {
  display: flex;
  align-items: center;
  gap: 20px;
}
.ci-qty {
  width: 80px;
  padding: 10px;
  border: 1px solid \-border;
  border-radius: 8px;
  text-align: center;
  font-weight: 600;
}
.ci-remove {
  color: #E07A5F;
  font-size: 14px;
  text-decoration: underline;
  transition: \-smooth;
}
.ci-remove:hover {
  color: \-text-main;
}
.ci-total {
  font-size: 22px;
  font-weight: 800;
  color: \-text-main;
  padding-right: 20px;
}

.cart-summary-column {
  padding: 40px;
  border-radius: 20px;
  align-self: start;
  position: sticky;
  top: 140px;
}
.summary-title {
  font-size: 28px;
  font-weight: 800;
  margin-bottom: 30px;
  border-bottom: 2px solid \-border;
  padding-bottom: 20px;
}
.summary-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20px;
  font-size: 18px;
  color: \-text-light;
}
.shipping-row {
  padding: 20px 0;
  border-top: 1px dashed \-border;
  border-bottom: 1px dashed \-border;
  margin: 30px 0;
  background: rgba(122,139,106, 0.03);
  margin-left: -40px;
  margin-right: -40px;
  padding-left: 40px;
  padding-right: 40px;
}
.total-row {
  font-size: 28px;
  font-weight: 800;
  color: \-text-main;
  margin-bottom: 30px;
}

.cart-note-label {
  font-size: 14px;
  font-weight: 600;
  margin-bottom: 10px;
}
.cart-note-input {
  width: 100%;
  border: 1px solid \-border;
  border-radius: 12px;
  padding: 15px;
  min-height: 80px;
  margin-bottom: 25px;
}
.trust-badges-cart {
  margin-top: 25px;
  text-align: center;
  color: \-text-light;
  font-size: 14px;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 10px;
}
.trust-badges-cart svg {
  color: \-accent;
}
