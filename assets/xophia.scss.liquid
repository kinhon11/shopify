/* Xophia Custom Styles */


  $color-primary-bg: #FDFBF7; /* Warm beige / soft cream */
  $color-accent: #7A8B6A; /* Olive green */
  $color-accent-hover: #637254;
  $color-text-main: #2C2C2C; /* Dark grey for elegant text */
  $color-text-light: #666666;
  $color-white: #FFFFFF;
  $color-border: #E8E8E8;
  
  $font-family-main: 'Inter', 'Helvetica Neue', Arial, sans-serif;
  $font-family-heading: 'Outfit', 'Helvetica Neue', Arial, sans-serif;
  
  $radius-sm: 8px;
  $radius-md: 16px;
  $radius-lg: 24px;
  
  $shadow-soft: 0 10px 30px rgba(0,0,0,0.05);
  $shadow-hover: 0 15px 40px rgba(0,0,0,0.08);
  
  $transition-smooth: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);


body {
  font-family: $font-family-main;
  color: $color-text-main;
  background-color: $color-primary-bg;
  line-height: 1.6;
}

h1, h2, h3, h4, h5, h6 {
  font-family: $font-family-heading;
  font-weight: 500;
  color: $color-text-main;
  letter-spacing: -0.02em;
}

/* Base utilities */
.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 20px;
}

.text-center { text-align: center; }

.btn {
  display: inline-block;
  padding: 14px 28px;
  background-color: $color-accent;
  color: $color-white;
  border-radius: $radius-lg;
  font-weight: 500;
  transition: $transition-smooth;
  border: none;
  cursor: pointer;
  text-decoration: none;
  font-family: $font-family-main;
}
.btn:hover {
  background-color: $color-accent-hover;
  transform: translateY(-2px);
  box-shadow: $shadow-soft;
  color: $color-white;
}
.btn--outline {
  background-color: transparent;
  border: 1px solid $color-accent;
  color: $color-accent;
}
.btn--outline:hover {
  background-color: $color-accent;
  color: $color-white;
}

/* Header */
.xophia-header {
  position: sticky;
  top: 0;
  z-index: 1000;
  background-color: rgba(253, 251, 247, 0.9);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid $color-border;
  padding: 15px 0;
  transition: $transition-smooth;
}
.xophia-header-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.header-logo a {
  font-family: $font-family-heading;
  font-size: 28px;
  font-weight: 600;
  color: $color-text-main;
  text-decoration: none;
  letter-spacing: -0.03em;
}
.header-nav {
  display: none;
}
@media (min-width: 768px) {
  .header-nav {
    display: flex;
    gap: 30px;
  }
}
.header-nav a {
  color: $color-text-main;
  text-decoration: none;
  font-size: 15px;
  font-weight: 500;
  transition: color 0.2s;
}
.header-nav a:hover {
  color: $color-accent;
}
.header-icons {
  display: flex;
  gap: 20px;
  align-items: center;
}
.header-icons a {
  color: $color-text-main;
  cursor: pointer;
  display: flex;
  position: relative;
  text-decoration: none;
}
.header-icons svg {
  width: 22px;
  height: 22px;
}
.cart-count {
  position: absolute;
  top: -8px;
  right: -8px;
  background: $color-accent;
  color: $color-white;
  font-size: 11px;
  width: 18px;
  height: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-weight: 600;
}

/* Hero Section */
.hero-section {
  padding: 80px 20px;
  background-color: #F4EFE6;
  border-radius: $radius-lg;
  margin: 20px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.hero-content {
  max-width: 600px;
  margin: 0 auto;
  position: relative;
  z-index: 2;
}
.hero-title {
  font-size: 48px;
  line-height: 1.1;
  margin-bottom: 20px;
}
@media (max-width: 767px) {
  .hero-title {
    font-size: 36px;
  }
}
.hero-subtitle {
  font-size: 18px;
  color: $color-text-light;
  margin-bottom: 30px;
}

/* Trust Section */
.trust-section {
  padding: 40px 0;
  background-color: $color-white;
  border-top: 1px solid $color-border;
  border-bottom: 1px solid $color-border;
}
.trust-grid {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 20px;
}
.trust-item {
  display: flex;
  align-items: center;
  gap: 12px;
  flex: 1;
  min-width: 200px;
}
.trust-icon {
  width: 40px;
  height: 40px;
  background: $color-primary-bg;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: $color-accent;
}
.trust-text {
  font-weight: 500;
  font-size: 14px;
}

/* Featured Products */
.featured-products {
  padding: 80px 0;
}
.section-header {
  text-align: center;
  margin-bottom: 50px;
}
.section-title {
  font-size: 32px;
  margin-bottom: 10px;
}
.product-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 30px;
}
.product-card {
  background: $color-white;
  border-radius: $radius-md;
  padding: 15px;
  transition: $transition-smooth;
  box-shadow: 0 4px 6px rgba(0,0,0,0.02);
  text-align: center;
  position: relative;
}
.product-card:hover {
  transform: translateY(-5px);
  box-shadow: $shadow-hover;
}
.product-image-wrap {
  position: relative;
  padding-bottom: 100%;
  border-radius: $radius-sm;
  background: #f9f9f9;
  overflow: hidden;
  margin-bottom: 15px;
}
.product-image-wrap img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: contain;
}
.discount-badge {
  position: absolute;
  top: 10px;
  left: 10px;
  background: #E07A5F; /* Terracotta */
  color: white;
  padding: 4px 10px;
  font-size: 12px;
  font-weight: 600;
  border-radius: 20px;
  z-index: 2;
}
.product-title {
  font-size: 16px;
  font-weight: 500;
  margin-bottom: 10px;
  color: $color-text-main;
  text-decoration: none;
  display: block;
}
.product-price {
  font-weight: 600;
  color: $color-accent;
  margin-bottom: 15px;
}
.add-to-cart-btn {
  width: 100%;
  padding: 10px;
  font-size: 14px;
}

/* Benefits Section */
.benefits-section {
  padding: 80px 0;
  background-color: $color-white;
}
.benefits-wrapper {
  display: flex;
  align-items: center;
  gap: 50px;
  flex-wrap: wrap;
}
.benefits-content {
  flex: 1;
  min-width: 300px;
}
.benefits-list {
  list-style: none;
  padding: 0;
  margin-top: 30px;
}
.benefits-list li {
  display: flex;
  align-items: flex-start;
  gap: 15px;
  margin-bottom: 25px;
}
.benefit-icon {
  background: rgba(122, 139, 106, 0.1);
  color: $color-accent;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.benefit-icon svg { width: 24px; height: 24px; }
.benefit-text h4 { margin: 0 0 5px 0; font-size: 18px; }
.benefit-text p { margin: 0; color: $color-text-light; font-size: 14px; }
.benefits-image {
  flex: 1;
  min-width: 300px;
  border-radius: $radius-lg;
  overflow: hidden;
}
.benefits-image img {
  width: 100%;
  height: auto;
  display: block;
}

/* Reviews Section */
.reviews-section {
  padding: 80px 0;
}
.reviews-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 30px;
}
.review-card {
  background: $color-white;
  padding: 30px;
  border-radius: $radius-md;
  box-shadow: $shadow-soft;
}
.stars {
  color: #F4C150;
  margin-bottom: 15px;
}
.review-text {
  font-style: italic;
  margin-bottom: 20px;
  color: $color-text-main;
  font-size: 15px;
}
.reviewer-name {
  font-weight: 600;
  font-size: 14px;
}

/* Footer */
.xophia-footer {
  background-color: $color-white;
  padding: 60px 0 30px;
  border-top: 1px solid $color-border;
}
.footer-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 40px;
  margin-bottom: 40px;
}
.footer-col h4 {
  font-size: 16px;
  margin-bottom: 20px;
  font-weight: 600;
}
.footer-col ul {
  list-style: none;
  padding: 0;
  margin: 0;
}
.footer-col ul li {
  margin-bottom: 10px;
}
.footer-col ul li a {
  color: $color-text-light;
  text-decoration: none;
  transition: color 0.2s;
  font-size: 14px;
}
.footer-col ul li a:hover {
  color: $color-accent;
}
.social-icons {
  display: flex;
  gap: 15px;
  margin-top: 15px;
}
.social-icons a {
  color: $color-text-main;
  background: $color-primary-bg;
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: $transition-smooth;
}
.social-icons a:hover {
  background: $color-accent;
  color: $color-white;
}
.footer-bottom {
  text-align: center;
  padding-top: 30px;
  border-top: 1px solid $color-border;
  color: $color-text-light;
  font-size: 13px;
}
