/* ==========================================================================
   XOPHIA - THE PREMIUM ITALIAN EDITORIAL THEME (V3)
   A luxury multi-category marketplace.
   ========================================================================== */

$color-bg: #FFFFFF;
$color-text: #111111;
$color-text-light: #777777;
$color-border: #E5E5E5;
$color-accent: #B88645; /* Luxury Gold/Bronze */
$color-accent-dark: #8A6433;

$font-heading: 'Cormorant Garamond', serif;
$font-body: 'Montserrat', sans-serif;

body {
  background-color: $color-bg !important;
  color: $color-text !important;
  font-family: $font-body !important;
  -webkit-font-smoothing: antialiased;
  margin: 0;
  padding: 0;
}

h1, h2, h3, h4, h5, h6, .heading-font {
  font-family: $font-heading !important;
  color: $color-text !important;
  font-weight: 400;
  margin: 0;
}

a {
  color: $color-text;
  text-decoration: none;
  transition: all 0.3s ease;
}
a:hover {
  color: $color-accent;
}

/* Base button */
.btn-editorial {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 18px 40px;
  background: $color-text;
  color: $color-bg !important;
  font-family: $font-body;
  font-size: 13px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 2px;
  border: 1px solid $color-text;
  cursor: pointer;
  transition: all 0.4s ease;
  width: 100%;
}
.btn-editorial:hover {
  background: $color-bg;
  color: $color-text !important;
}

/* --------------------------------------------------------------------------
   HEADER
   -------------------------------------------------------------------------- */
.editorial-header {
  border-bottom: 1px solid $color-border;
  background: rgba(255,255,255,0.98);
  position: sticky;
  top: 0;
  z-index: 1000;
  backdrop-filter: blur(10px);
}
.top-bar {
  background: $color-text;
  color: $color-bg;
  text-align: center;
  padding: 10px 0;
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  font-family: $font-body;
}
.top-bar strong { color: $color-accent; font-weight: 600; }
.header-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 25px 4vw;
}
.logo-container a {
  font-family: $font-heading;
  font-size: 44px;
  letter-spacing: 0.2em;
  color: $color-text;
  text-transform: uppercase;
  display: block;
}
.nav-links {
  display: flex;
  gap: 40px;
}
.nav-links a {
  font-size: 12px;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  font-weight: 500;
  position: relative;
}
.nav-links a::after {
  content: '';
  position: absolute;
  bottom: -4px; left: 0; width: 0; height: 1px;
  background: $color-text;
  transition: width 0.3s ease;
}
.nav-links a:hover::after { width: 100%; }

.header-actions {
  display: flex;
  gap: 25px;
  align-items: center;
}
.header-actions svg { width: 22px; height: 22px; cursor: pointer; transition: color 0.3s; }
.header-actions svg:hover { color: $color-accent; }
.cart-wrap { position: relative; display: flex; align-items: center; }
.cart-count {
  position: absolute; top: -8px; right: -10px;
  background: $color-accent; color: #fff;
  font-size: 10px; font-weight: bold;
  padding: 2px 6px; border-radius: 10px;
}

/* --------------------------------------------------------------------------
   HERO / INDEX
   -------------------------------------------------------------------------- */
.editorial-hero {
  height: 90vh;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  overflow: hidden;
  background: #111;
}
.hero-video {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  min-width: 100%; min-height: 100%;
  opacity: 0.65;
  object-fit: cover;
  z-index: 1;
}
.hero-content {
  position: relative;
  z-index: 2;
  color: #fff;
  padding: 0 20px;
}
.hero-tag {
  font-size: 12px;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: $color-accent;
  margin-bottom: 20px;
  display: block;
}
.hero-content h1 {
  color: #fff !important;
  font-size: 90px;
  font-weight: 300;
  letter-spacing: 0.02em;
  line-height: 1;
  margin-bottom: 30px;
}
.hero-content p {
  font-size: 16px;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 50px;
  font-weight: 300;
}
.btn-hero {
  border-color: #fff;
  color: #fff !important;
  background: transparent;
  width: auto;
}
.btn-hero:hover {
  background: #fff;
  color: $color-text !important;
}

/* Category Grid */
.category-showcase {
  padding: 2vw;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2vw;
}
@media (max-width: 900px) {
  .category-showcase { grid-template-columns: repeat(2, 1fr); }
}
.cat-box {
  position: relative;
  aspect-ratio: 3/4;
  overflow: hidden;
  background: #f4f4f4;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 40px;
  text-decoration: none;
}
.cat-box img {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  object-fit: cover;
  transition: transform 1.2s cubic-bezier(0.19, 1, 0.22, 1);
}
.cat-box:hover img { transform: scale(1.08); }
.cat-box .overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.5), transparent 60%);
}
.cat-title-wrap {
  position: relative;
  z-index: 2;
  text-align: center;
}
.cat-box h3 {
  color: #fff !important;
  font-size: 42px;
  margin-bottom: 10px;
  font-style: italic;
}
.cat-box span {
  color: $color-bg;
  font-family: $font-body;
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  border-bottom: 1px solid transparent;
  transition: border-color 0.3s;
}
.cat-box:hover span { border-color: $color-accent; color: $color-accent; }

/* Product Scroller */
.editorial-products {
  padding: 120px 4vw;
  background: #FAFAFA;
}
.section-title-wrap {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 60px;
  padding-bottom: 20px;
  border-bottom: 1px solid $color-border;
}
.section-title-wrap h2 {
  font-size: 56px;
  font-weight: 400;
}
.section-title-wrap a {
  font-size: 12px;
  letter-spacing: 2px;
  text-transform: uppercase;
  font-weight: 500;
  border-bottom: 1px solid $color-text;
  padding-bottom: 5px;
}
.prod-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 40px;
}
.prod-card {
  text-align: left;
  position: relative;
}
.prod-img {
  aspect-ratio: 3/4;
  overflow: hidden;
  margin-bottom: 25px;
  background: #f0f0f0;
  position: relative;
}
.prod-img img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform 0.8s ease;
}
.prod-card:hover .prod-img img { transform: scale(1.05); }
.prod-brand {
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: $color-accent;
  display: block;
  margin-bottom: 8px;
}
.prod-title {
  font-family: $font-heading;
  font-size: 26px;
  display: block;
  margin-bottom: 12px;
  line-height: 1.2;
}
.prod-price {
  font-size: 15px;
  font-weight: 500;
}
.prod-quick-add {
  position: absolute;
  bottom: 0; left: 0; width: 100%;
  background: $color-text; color: #fff;
  text-align: center; padding: 15px;
  text-transform: uppercase; font-size: 11px; letter-spacing: 2px;
  transform: translateY(100%); transition: transform 0.4s ease;
  border: none; cursor: pointer;
}
.prod-img:hover .prod-quick-add { transform: translateY(0); }
.prod-quick-add:hover { background: $color-accent; }

/* --------------------------------------------------------------------------
   FOOTER
   -------------------------------------------------------------------------- */
.editorial-footer {
  background: #111;
  color: #fff;
  padding: 100px 4vw 40px;
}
.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1.5fr;
  gap: 60px;
  margin-bottom: 80px;
}
.editorial-footer h4 {
  color: #fff !important;
  font-family: $font-body !important;
  font-size: 11px;
  letter-spacing: 3px;
  text-transform: uppercase;
  margin-bottom: 30px;
  opacity: 0.5;
}
.editorial-footer ul { list-style: none; padding: 0; margin: 0; }
.editorial-footer li { margin-bottom: 15px; }
.editorial-footer p, .editorial-footer a {
  color: #ccc;
  font-size: 14px;
}
.editorial-footer a:hover { color: #fff; }
.footer-brand {
  font-family: $font-heading;
  font-size: 54px;
  letter-spacing: 0.1em;
  color: #fff;
  display: block;
  margin-bottom: 25px;
}
.newsletter-box {
  display: flex;
  border-bottom: 1px solid #555;
  padding-bottom: 10px;
  margin-top: 20px;
}
.newsletter-box input {
  background: transparent; border: none; color: #fff;
  flex: 1; font-family: $font-body; font-size: 13px; outline: none;
}
.newsletter-box button {
  background: transparent; border: none; color: #fff;
  text-transform: uppercase; font-size: 11px; letter-spacing: 1px; cursor: pointer;
}
.footer-bottom {
  border-top: 1px solid #333;
  padding-top: 30px;
  display: flex;
  justify-content: space-between;
  font-size: 12px;
  color: #666;
  text-transform: uppercase;
  letter-spacing: 1px;
}

/* --------------------------------------------------------------------------
   PRODUCT PAGE
   -------------------------------------------------------------------------- */
.ed-product-wrap {
  padding: 80px 4vw;
  display: grid;
  grid-template-columns: 1.5fr 1fr;
  gap: 100px;
  max-width: 1600px;
  margin: 0 auto;
}
@media (max-width: 900px) { .ed-product-wrap { grid-template-columns: 1fr; } }
.ed-gallery {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}
.ed-gallery img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  aspect-ratio: 3/4;
  background: #f9f9f9;
}
.ed-info {
  position: sticky;
  top: 120px;
}
.ed-brand-tag {
  color: $color-accent;
  font-size: 12px;
  letter-spacing: 3px;
  text-transform: uppercase;
  display: block;
  margin-bottom: 20px;
  font-weight: 600;
}
.ed-title {
  font-size: 56px;
  line-height: 1.1;
  margin-bottom: 30px;
}
.ed-price {
  font-size: 26px;
  font-family: $font-body;
  font-weight: 400;
  margin-bottom: 40px;
  display: flex;
  align-items: center;
  gap: 15px;
}
.ed-price s { color: #999; font-size: 20px; }
.ed-desc {
  font-size: 15px;
  line-height: 1.8;
  color: $color-text-light;
  margin-bottom: 50px;
  padding-bottom: 40px;
  border-bottom: 1px solid $color-border;
}
.ed-form {
  margin-bottom: 40px;
}
.qty-selector {
  display: flex;
  border: 1px solid $color-border;
  width: 150px;
  margin-bottom: 25px;
}
.qty-selector button {
  background: transparent; border: none; width: 50px; height: 50px;
  font-size: 20px; cursor: pointer;
}
.qty-selector input {
  width: 50px; border: none; text-align: center;
  font-family: $font-body; font-size: 16px; font-weight: 500;
  -moz-appearance: textfield;
}
.qty-selector input::-webkit-outer-spin-button, .qty-selector input::-webkit-inner-spin-button {
  -webkit-appearance: none;
}
.ed-trust {
  margin-top: 50px;
  padding-top: 40px;
  border-top: 1px solid $color-border;
}
.ed-trust-row {
  display: flex;
  align-items: flex-start;
  gap: 20px;
  margin-bottom: 25px;
}
.ed-trust-row svg { width: 24px; color: $color-text; margin-top: 5px; }
.ed-trust-info h5 { font-family: $font-body !important; font-size: 12px; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 5px; font-weight: 600; }
.ed-trust-info p { font-size: 13px; color: $color-text-light; margin: 0; }

/* --------------------------------------------------------------------------
   CART PAGE
   -------------------------------------------------------------------------- */
.ed-cart-container {
  padding: 100px 4vw;
  max-width: 1400px;
  margin: 0 auto;
}
.ed-cart-header {
  margin-bottom: 80px;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  border-bottom: 1px solid $color-border;
  padding-bottom: 20px;
}
.ed-cart-header h1 {
  font-size: 64px;
}
.ed-cart-continue {
  font-size: 12px; text-transform: uppercase; letter-spacing: 2px;
  border-bottom: 1px solid $color-text; padding-bottom: 5px;
}
.ed-cart-grid {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 80px;
}
@media (max-width: 900px) { .ed-cart-grid { grid-template-columns: 1fr; } }
.ed-cart-list {
  border-top: 1px solid $color-border;
}
.ed-cart-item {
  display: flex;
  gap: 40px;
  padding: 40px 0;
  border-bottom: 1px solid $color-border;
}
.ed-cart-img {
  width: 160px;
  aspect-ratio: 3/4;
  object-fit: cover;
}
.ed-cart-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.ed-cart-brand {
  font-size: 10px; text-transform: uppercase; letter-spacing: 2px; color: $color-text-light; margin-bottom: 10px;
}
.ed-cart-title {
  font-family: $font-heading;
  font-size: 32px;
  display: block;
  margin-bottom: 15px;
}
.ed-cart-price {
  font-family: $font-body;
  font-size: 18px;
  margin-bottom: 30px;
}
.ed-cart-actions {
  display: flex;
  align-items: center;
  gap: 40px;
}
.ed-cart-remove {
  font-size: 12px; text-transform: uppercase; letter-spacing: 1px; color: #d00;
  border-bottom: 1px solid #d00;
}
.ed-cart-summary {
  background: #FAFAFA;
  padding: 50px;
  position: sticky;
  top: 120px;
}
.ed-summary-title {
  font-size: 32px;
  margin-bottom: 40px;
  border-bottom: 1px solid $color-border;
  padding-bottom: 20px;
}
.ed-summary-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 25px;
  font-size: 15px;
  text-transform: uppercase;
  letter-spacing: 1px;
}
.ed-summary-total {
  font-family: $font-heading;
  font-size: 42px;
  border-top: 1px solid $color-border;
  padding-top: 25px;
  margin-top: 25px;
  margin-bottom: 40px;
  text-transform: none;
}
.ed-payment {
  margin-bottom: 40px;
}
.ed-payment label {
  display: block; margin-bottom: 15px; font-size: 13px; text-transform: uppercase; letter-spacing: 1px; border: 1px solid $color-border; padding: 15px; cursor: pointer;
}
.ed-payment input { margin-right: 15px; }
