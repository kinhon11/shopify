<!doctype html>
<!--[if IE 8]><html class="no-js lt-ie9" lang="en"> <![endif]-->
<!--[if IE 9 ]><html class="ie9 no-js"> <![endif]-->
<!--[if (gt IE 9)|!(IE)]><!--> <html class="no-js"> <!--<![endif]-->
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">

  <title>
    {{ page_title }}{% if current_tags %}{% assign meta_tags = current_tags | join: ', ' %} &ndash; {{ 'general.meta.tags' | t: tags: meta_tags }}{% endif %}{% if current_page != 1 %} &ndash; {{ 'general.meta.page' | t: page: current_page }}{% endif %}{% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}
  </title>

  {% if page_description %}
  <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <link rel="canonical" href="{{ canonical_url }}">
  <meta name="viewport" content="width=device-width,initial-scale=1,shrink-to-fit=no">

  <!-- FONTS -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">

  <!-- CSS -->
  {{ 'timber.scss.css' | asset_url | stylesheet_tag }}
  {{ 'xophia.scss.css' | asset_url | stylesheet_tag }}

  {{ content_for_header }}
  
  {{ '//ajax.googleapis.com/ajax/libs/jquery/1.12.4/jquery.min.js' | script_tag }}
  {{ 'modernizr.min.js' | asset_url | script_tag }}
  {% if template contains 'customers' %}
    {{ 'shopify_common.js' | shopify_asset_url | script_tag }}
  {% endif %}
</head>

<body id="{{ page_title | handle }}" class="template-{{ template | replace: '.', ' ' | truncatewords: 1, '' | handle }} xophia-premium-editorial" >

  <!-- ULTRA LUXURY TOP BAR -->
  <div class="top-bar">
    SPEDIZIONE GRATUITA SOPRA I <strong>50 EURO</strong> IN TUTTA ITALIA.
  </div>

  <header class="editorial-header">
    <div class="header-main">
      <!-- Mega Nav Links -->
      <nav class="nav-links">
        <a href="/collections/all">Moda (Fashion)</a>
        <a href="/collections/all">Casa (Home)</a>
        <a href="/collections/all">Bellezza (Beauty)</a>
        <a href="/pages/contact">Chi Siamo (About)</a>
      </nav>

      <!-- Center Typography Logo -->
      <div class="logo-container">
        <a href="/" itemprop="url">
          Xophia
        </a>
      </div>

      <!-- Actions -->
      <div class="header-actions">
        <!-- Search -->
        <a href="/search" title="Cerca">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
        </a>
        <!-- Account -->
        {% if shop.customer_accounts_enabled %}
          <a href="/account" title="Account">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
          </a>
        {% endif %}
        <!-- Cart -->
        <a href="/cart" class="cart-wrap" title="Carrello">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
          <span class="cart-count">{{ cart.item_count }}</span>
        </a>
      </div>
    </div>
  </header>

  <main role="main">
    {{ content_for_layout }}
  </main>

  <footer class="editorial-footer">
    <div class="footer-grid">
      <!-- Brand -->
      <div>
        <span class="footer-brand">Xophia</span>
        <p>Il più grande department store di lusso in Italia. Scopri l'eleganza della moda, della casa e dell'arte di vivere.</p>
        <div class="newsletter-box">
          <input type="email" placeholder="ISCRIVITI ALLA NEWSLETTER">
          <button>→</button>
        </div>
      </div>
      
      <!-- Nav 1 -->
      <div>
        <h4>Esplora</h4>
        <ul>
          <li><a href="/collections/all">La Moda (Fashion)</a></li>
          <li><a href="/collections/all">La Casa (Home)</a></li>
          <li><a href="/collections/all">Elettronica (Tech)</a></li>
          <li><a href="/collections/all">La Bellezza (Beauty)</a></li>
        </ul>
      </div>

      <!-- Nav 2 -->
      <div>
        <h4>Servizi</h4>
        <ul>
          <li><a href="/pages/shipping">Spedizione e Resi</a></li>
          <li><a href="/pages/contact">Servizio Clienti</a></li>
          <li><a href="/pages/payment">Pagamenti Sicuri</a></li>
          <li><a href="/pages/faq">F.A.Q</a></li>
        </ul>
      </div>

      <!-- Info -->
      <div>
        <h4>Boutique</h4>
        <ul>
          <li>Via Montenapoleone 18, Milano, IT</li>
          <li>Lun - Sab: 10:00 - 19:30</li>
          <li>Dom: 11:00 - 19:00</li>
          <li>support@xophia.it</li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <span>&copy; {{ 'now' | date: "%Y" }} Xophia Italia s.r.l. Tutti i diritti riservati.</span>
      <span>P.IVA 12345678901 - Note Legali</span>
    </div>
  </footer>

  {{ 'fastclick.min.js' | asset_url | script_tag }}
  {{ 'timber.js' | asset_url | script_tag }}
</body>
</html>
